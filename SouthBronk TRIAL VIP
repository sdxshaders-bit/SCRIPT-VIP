	local function isCompletelyClear()
		local hrp = getHRP()
		if not hrp then return true end
		local hits = 0
		for _, d in ipairs(rayDirections) do
			local r = workspace:Raycast(hrp.Position, d * 2.5, getRayParams())
			if r and r.Instance and r.Instance.CanCollide then hits = hits + 1 end
		end
		return hits < 2
