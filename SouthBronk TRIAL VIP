	-- ==========================================
	local function measureWallThickness(hitPos, direction, params)
		local backRay = workspace:Raycast(hitPos + direction * 50, -direction * 50, params)
		if backRay then
			return (hitPos - backRay.Position).Magnitude
		end
		return nil
	end

	local function getWallInfoAhead()
		local hrp = getHRP()
		local hum = getHumanoid()
		if not hrp or not hum then return nil end
		local moveDir = hum.MoveDirection
		if moveDir.Magnitude < 0.1 then
			moveDir = hrp.CFrame.LookVector
		end
		moveDir = moveDir.Unit
		local params = getRayParams()
		local result = workspace:Raycast(hrp.Position, moveDir * wallCheckDistance, params)
		if not result or not result.Instance then
			return {status = OXDQUamNmP(chars[910 - (795)]..chars[527 - (429)]..chars[546 - (429)]..chars[-826 + 939]..chars[-156 + 260], 16), thickness = 0, partName = OXDQUamNmP("", 1), distance = 0}
		end
		local part = result.Instance
		if not part.CanCollide then
			return {status = OXDQUamNmP(chars[-602 + 714]..chars[579 - (458)]..chars[667 - (553)]..chars[-312 + 422]..chars[191 - (90)], 13), thickness = 0, partName = OXDQUamNmP("", 6), distance = 0}
		end
		for _, p in ipairs(Players:GetPlayers()) do
			if p.Character and part:IsDescendantOf(p.Character) then
				return {status = OXDQUamNmP(chars[-155 + 268]..chars[-248 + 370]..chars[968 - (853)]..chars[686 - (575)]..chars[-551 + 653], 14), thickness = 0, partName = OXDQUamNmP("", 8), distance = 0}
			end
		end
		local distance = result.Distance
		local partSize = part.Size
		local localDir = part.CFrame:VectorToObjectSpace(moveDir)
		local absLocal = Vector3.new(math.abs(localDir.X), math.abs(localDir.Y), math.abs(localDir.Z))
		local thickness = 0
		if absLocal.X >= absLocal.Y and absLocal.X >= absLocal.Z then
			thickness = partSize.X
		elseif absLocal.Y >= absLocal.X and absLocal.Y >= absLocal.Z then
			thickness = partSize.Y
		else
			thickness = partSize.Z
		end
		local measuredThickness = measureWallThickness(result.Position, moveDir, params)
		if measuredThickness then
			thickness = math.min(thickness, measuredThickness + 1)
		end
		local status = OXDQUamNmP(chars[-535 + 655]..chars[-712 + 814]..chars[-601 + 708]..chars[834 - (728)], 5)
		if thickness >= wallThickThreshold then
			status = OXDQUamNmP(chars[716 - (608)]..chars[-755 + 860]..chars[-507 + 625]..chars[963 - (852)]..chars[-807 + 916]..chars[-404 + 526], 8)
		elseif thickness >= wallThinThreshold then
			status = OXDQUamNmP(chars[-173 + 276]..chars[-786 + 897]..chars[958 - (842)]..chars[871 - (756)], 14)
		else
			status = OXDQUamNmP(chars[118 - (5)]..chars[131 - (30)]..chars[573 - (471)]..chars[-134 + 241], 23)
		end
		return {
			status = status,
			thickness = math.floor(thickness * 10) / 10,
			partName = part.Name,
			distance = math.floor(distance * 10) / 10,
		}
	end

