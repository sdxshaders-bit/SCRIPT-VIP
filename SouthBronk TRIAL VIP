	local function isStuck()
		local hrp = getHRP()
		if not hrp then return false end
		if not lastPosition then lastPosition = hrp.Position return false end
		local hum = getHumanoid()
		if not hum then return false end
		local moving = hum.MoveDirection.Magnitude > 0.1
		local moved = (hrp.Position - lastPosition).Magnitude > 0.05
		lastPosition = hrp.Position
		if moving and not moved then stuckCounter = stuckCounter + 1 return stuckCounter >= STUCK_THRESHOLD
		else stuckCounter = 0 end
		return false
	end

